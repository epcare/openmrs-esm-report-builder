{
  "name": "@openmrs/esm-report-builder",
  "version": "0.1.0",
  "license": "MPL-2.0",
  "description": "OpenMRS ESM Report Builder",
  "browser": "dist/openmrs-esm-report-builder.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "build": "openmrs build --build-mode=production",
    "analyze": "openmrs build --build-mode=production --analyze",
    "lint": "eslint --ext js,jsx,ts,tsx .",
    "typescript": "tsc",
    "test": "jest",
    "coverage": "jest --coverage",
    "verify": "npm-run-all --parallel lint test typescript"
  },
  "dependencies": {
    "@carbon/react": "^1.39.0",
    "@carbon/icons-react": "^11.58.0",
    "lodash-es": "^4.17.21",
    "react-ace": "^10.1.0",
    "sass": "^1.83.0"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "next",
    "@openmrs/esm-styleguide": "next",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/webpack-env": "^1.18.5",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "css-loader": "^6.11.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "openmrs": "next",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "rxjs": "^6.6.7",
    "swc-loader": "^0.2.6",
    "typescript": "^5.0.0",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "^8.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-i18next": "^16.0.0",
    "rxjs": "^6.6.7",
    "single-spa": "^5.0.0"
  },
  "openmrs": {
    "buildPath": "dist",
    "rootDir": "src",
    "config": {
      "paths": {
        "@openmrs/esm-report-builder": ["src"]
      }
    }
  }
}