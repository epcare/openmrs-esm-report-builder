{
  "name": "@epcare/esm-report-builder",
  "version": "0.1.0",
  "license": "MPL-2.0",
  "description": "OpenMRS ESM Report Builder",
  "browser": "dist/openmrs-esm-report-builder.js",
  "main": "src/index.ts",
  "source": true,
  "files": [
    "*"
  ],
  "scripts": {
    "start": "openmrs develop",
    "build": "openmrs build",
    "analyze": "openmrs build --analyze",
    "lint": "eslint --ext js,jsx,ts,tsx .",
    "typescript": "tsc",
    "test": "jest --passWithNoTests",
    "coverage": "jest --coverage --passWithNoTests",
    "verify": "npm-run-all --parallel lint test typescript",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install"
  },
  "dependencies": {
    "@carbon/icons-react": "^11.58.0",
    "@carbon/react": "^1.39.0",
    "@react-aria/utils": "^3.31.0",
    "@react-types/shared": "^3.32.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.13",
    "lodash-es": "^4.17.21",
    "react-ace": "^10.1.0",
    "react-aria": "^3.44.0",
    "react-router-dom": "^6.30.1",
    "react-stately": "^3.42.0",
    "sass": "^1.83.0",
    "single-spa-react": "^6.0.2",
    "swr": "^2.2.5",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@openmrs/esm-framework": "next",
    "@openmrs/esm-styleguide": "next",
    "@playwright/test": "^1.58.2",
    "@swc/core": "^1.7.36",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.12",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/webpack-env": "^1.18.5",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "css-loader": "^6.11.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "openmrs": "next",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "rxjs": "^6.6.7",
    "single-spa": "^5.9.5",
    "swc-loader": "^0.2.6",
    "typescript": "5.5.4"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "^8.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-i18next": "^16.0.0",
    "rxjs": "^6.6.7",
    "single-spa": "^5.0.0"
  },
  "resolutions": {
    "zustand": "^4.5.7"
  },
  "openmrs": {
    "buildPath": "dist",
    "rootDir": "src",
    "config": {
      "paths": {
        "@epcare/esm-report-builder": [
          "src"
        ]
      }
    }
  },
  "packageManager": "yarn@4.10.3"
}
